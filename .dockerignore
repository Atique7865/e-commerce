# =============================================================================
# .dockerignore — exclude files that shouldn't be in the Docker image
# =============================================================================

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/
.env/

# Environment files (secrets must not leak into image layers)
.env
.env.*
!.env.example

# Version control
.git/
.gitignore
.gitattributes

# Docker files (not needed inside the container)
Dockerfile*
docker-compose*.yml
.dockerignore

# Kubernetes & infra (not needed inside the container)
k8s/
nginx/

# Dev / IDE
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# Tests & docs
tests/
*.md
*.rst
docs/

# Media uploads (mounted as volume at runtime)
media/

# Collected static (regenerated during build)
staticfiles/

# Coverage / lint
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
